NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay
SESSION_SECRET=dev-session-secret-change-me
ENCRYPTION_MASTER_KEY=dev-encryption-key-change-me
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
JOBS_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Production notes:
# - Set NODE_ENV=production.
# - SESSION_SECRET and ENCRYPTION_MASTER_KEY must be unique strong values, at least 32 chars.
# - CORS_ORIGIN must be explicit HTTPS frontend origin(s), never wildcard.
