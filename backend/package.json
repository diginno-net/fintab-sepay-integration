{
  "name": "fintab-sepay-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/queue-worker.ts",
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx db/migrate.ts",
    "db:test:create": "createdb -h localhost -U postgres fintab_sepay_test 2>/dev/null || true",
    "db:test:setup": "npm run db:test:create && DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test tsx db/migrate.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/queue-worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:integration": "npm run db:test:setup && DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test vitest run tests/",
    "test:integration:smoke": "npm run db:test:setup && DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/fintab_sepay_test vitest run tests/readiness-health.test.ts tests/security-origin-guard.test.ts",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.3.3",
    "pg": "^8.13.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
